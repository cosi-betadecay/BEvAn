Bootstrap: docker
From: cosi:latest

%labels
    Author Arya Raeesi
    Description "COSI environment container for Savio (UC Berkeley)"
    Version 1.0

%files
    # If you want to include files directly into the container
    # localfile.txt /opt/localfile.txt

%post
    echo "Running post-install steps..."

    # Ensure permissions are correct for Apptainer execution on HPC
    chmod -R a+rX /home/cosi || true

    # Create runtime directories
    mkdir -p /run/user/1111 || true

    echo "Post section complete."

%environment
    export PATH="/home/cosi/.local/bin:${PATH}"
    export PYTHONUNBUFFERED=1
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Container running Python..."
    exec python3 "$@"